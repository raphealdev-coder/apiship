@page
@using apiship.Data
@model apiship.Pages.Account.BillingModel
@{
    ViewData["Title"] = "Subscription & billing";
    var monthlyNgn = Model.NgnFor(Model.MonthlyTotalUsd);
    var yearlyNgn = Model.NgnFor(Model.YearlyTotalUsd);
}

<section class="account-hero">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <a asp-page="/Account/Index" class="account-back">← Dashboard</a>
            <h1 class="mb-0">Store Sync &amp; API Connector</h1>
        </div>
        <div class="d-flex align-items-center gap-2">
            <a asp-page="/Account/AddStore" class="btn btn-brand">+ Add store</a>
            <a asp-page="/Account/Profile" class="btn btn-outline-light">Billing details</a>
            <form method="post" asp-page-handler="Logout" class="m-0">
                <button type="submit" class="btn btn-outline-light">Log out</button>
            </form>
        </div>
    </div>
</section>

<partial name="_TrialReminder" />

<section class="section">
    <div class="container" style="max-width:960px;">
        <p class="text-muted">
            The connector keeps inventory, prices and orders synchronised in real time across all your stores.
            Keep your subscription active to avoid synchronisation errors between branches.
        </p>

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="admin-flash">@Model.StatusMessage</div>
        }

        @if (Model.AllSubscribed)
        {
            <div class="sub-banner sub-banner--ok">
                <strong>✓ Your connector subscription is active.</strong>
                <span>Next billing @Model.Projects.Select(p => p.NextBillingUtc).Min().ToString("d MMMM yyyy") · billed @Model.Projects.First().BillingCycle.ToString().ToLowerInvariant().</span>
            </div>
        }
        else if (Model.TrialEnds is not null)
        {
            <div class="sub-banner sub-banner--trial">
                <span class="sub-banner-icon">⚠️</span>
                <div>
                    <strong>You're on the free trial connector.</strong>
                    <span>It expires on @Model.TrialEnds.Value.ToString("d MMMM yyyy"). Subscribe below to keep your stores in sync after that date.</span>
                </div>
            </div>
        }

        @if (Model.StoreCount == 0)
        {
            <div class="success-card mx-auto text-center mt-4">
                <div class="success-icon">🏪</div>
                <h3>No stores yet</h3>
                <p class="text-muted">Add a store to start syncing.</p>
                <a asp-page="/GetStarted" class="btn btn-brand">Add a store</a>
            </div>
        }
        else
        {
            <div class="sub-table-card">
                <table class="sub-table">
                    <thead>
                        <tr>
                            <th>Store</th>
                            <th>API key</th>
                            <th>Status</th>
                            <th class="text-end">Fee</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Projects)
                        {
                            var key = p.ApiKeys.FirstOrDefault(k => !k.Revoked)?.Prefix;
                            <tr>
                                <td>
                                    <span class="sub-store">@p.Name</span>
                                    <span class="admin-cell-sub">@(string.IsNullOrWhiteSpace(p.Location) ? ApiProductCatalog.DisplayName(p.ApiType) : p.Location)</span>
                                </td>
                                <td>
                                    @if (key is not null)
                                    {
                                        <code class="sub-key" data-key="@key">@key••••••</code>
                                        <button type="button" class="sub-copy" onclick="copyKey(this)">Copy</button>
                                    }
                                    else
                                    {
                                        <span class="admin-cell-sub">—</span>
                                    }
                                </td>
                                <td>
                                    @if (p.IsSubscribed)
                                    {
                                        <span class="status-chip status-chip--deployed">Active</span>
                                    }
                                    else if (p.IsInTrial)
                                    {
                                        <span class="status-chip status-chip--pending">Trial</span>
                                    }
                                    else
                                    {
                                        <span class="status-chip status-chip--rejected">Expired</span>
                                    }
                                </td>
                                <td class="text-end sub-fee">
                                    <span class="js-fee-amt">$@Model.PriceMonthlyUsd</span> <small class="js-fee-per">/ mo</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.AllSubscribed)
            {
                <form method="post" asp-page-handler="Subscribe" id="subscribeForm" class="sub-plan-card">
                    <h3 class="sub-plan-title">Choose a plan</h3>
                    <p class="sub-plan-applies">The plan you choose applies to <strong>all @Model.StoreCount store@(Model.StoreCount == 1 ? "" : "s")</strong> on your account.</p>
                    <div class="sub-plan-grid">
                        <label class="sub-plan">
                            <input type="radio" name="cycle" value="monthly" checked />
                            <span class="sub-plan-body">
                                <span class="sub-plan-name">Monthly</span>
                                <span class="sub-plan-desc">$@Model.PriceMonthlyUsd per store, billed monthly</span>
                            </span>
                        </label>
                        <label class="sub-plan">
                            <input type="radio" name="cycle" value="yearly" />
                            <span class="sub-plan-body">
                                <span class="sub-plan-name">Yearly <span class="sub-plan-tag">save vs monthly</span></span>
                                <span class="sub-plan-desc">$@Model.PriceYearlyUsd per store, billed yearly</span>
                            </span>
                        </label>
                    </div>

                    <div class="sub-plan-foot">
                        <div>
                            <div class="sub-total" id="subTotal">
                                @Model.StoreCount store@(Model.StoreCount == 1 ? "" : "s") × $@Model.PriceMonthlyUsd =
                                <strong>$@Model.MonthlyTotalUsd</strong> / month
                            </div>
                            <div class="sub-total-ngn" id="subTotalNgn">
                                Charged in Naira: ₦@monthlyNgn.ToString("N0") (at ₦@Model.Rate.ToString("N0")/$)
                            </div>
                        </div>
                        <button type="button" id="subBtn" class="btn btn-brand btn-lg" onclick="openConfirm()">Pay &amp; subscribe — $@Model.MonthlyTotalUsd/month</button>
                    </div>
                    <p class="sub-note">
                        Prices are in US dollars; you'll be charged the equivalent in Naira at today's rate on Paystack's
                        secure checkout. Your subscription activates automatically once payment is confirmed.
                    </p>
                </form>

                <div id="confirmModal" class="confirm-overlay" hidden>
                    <div class="confirm-box">
                        <h3 class="confirm-title">Confirm upgrade</h3>
                        <p id="confirmText" class="confirm-text"></p>
                        <div class="confirm-actions">
                            <button type="button" class="btn btn-outline-brand" onclick="closeConfirm()">Cancel</button>
                            <button type="button" class="btn btn-brand" onclick="proceedPay()">Confirm &amp; pay</button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>

@section Scripts {
    <script>
        function copyKey(btn) {
            var code = btn.previousElementSibling;
            var text = code ? (code.getAttribute('data-key') || code.textContent) : '';
            navigator.clipboard.writeText(text).then(function () {
                var old = btn.textContent; btn.textContent = 'Copied';
                setTimeout(function () { btn.textContent = old; }, 1200);
            });
        }

        (function () {
            var b = {
                stores: @Model.StoreCount,
                monthlyPer: @Model.PriceMonthlyUsd,
                yearlyPer: @Model.PriceYearlyUsd,
                monthlyTotal: @Model.MonthlyTotalUsd,
                yearlyTotal: @Model.YearlyTotalUsd,
                monthlyNgn: @Model.NgnFor(Model.MonthlyTotalUsd),
                yearlyNgn: @Model.NgnFor(Model.YearlyTotalUsd),
                rate: @Model.Rate.ToString(System.Globalization.CultureInfo.InvariantCulture)
            };
            function fmt(n) { return Number(n).toLocaleString('en-US'); }
            var checked = function () {
                var el = document.querySelector('input[name=cycle]:checked');
                return el ? el.value : 'monthly';
            };
            function update() {
                var yearly = checked() === 'yearly';
                var per = yearly ? b.yearlyPer : b.monthlyPer;
                var total = yearly ? b.yearlyTotal : b.monthlyTotal;
                var ngn = yearly ? b.yearlyNgn : b.monthlyNgn;
                var period = yearly ? 'year' : 'month';
                var perLabel = yearly ? '/ yr' : '/ mo';

                var totalEl = document.getElementById('subTotal');
                if (totalEl) {
                    totalEl.innerHTML = b.stores + ' store' + (b.stores === 1 ? '' : 's') +
                        ' × $' + fmt(per) + ' = <strong>$' + fmt(total) + '</strong> / ' + period;
                }
                var ngnEl = document.getElementById('subTotalNgn');
                if (ngnEl) {
                    ngnEl.textContent = 'Charged in Naira: ₦' + fmt(ngn) + ' (at ₦' + fmt(b.rate) + '/$)';
                }
                var btn = document.getElementById('subBtn');
                if (btn) {
                    btn.textContent = 'Pay & subscribe — $' + fmt(total) + '/' + period;
                }
                document.querySelectorAll('.js-fee-amt').forEach(function (el) { el.textContent = '$' + fmt(per); });
                document.querySelectorAll('.js-fee-per').forEach(function (el) { el.textContent = perLabel; });
            }
            document.querySelectorAll('input[name=cycle]').forEach(function (r) {
                r.addEventListener('change', update);
            });
            update();

            window.openConfirm = function () {
                var yearly = checked() === 'yearly';
                var total = yearly ? b.yearlyTotal : b.monthlyTotal;
                var ngn = yearly ? b.yearlyNgn : b.monthlyNgn;
                var period = yearly ? 'year' : 'month';
                var planName = yearly ? 'Yearly' : 'Monthly';
                var txt = document.getElementById('confirmText');
                if (txt) {
                    txt.innerHTML = "You're upgrading <strong>all " + b.stores + " store" + (b.stores === 1 ? '' : 's') +
                        "</strong> to the <strong>" + planName + "</strong> plan.<br>" +
                        "You'll pay <strong>$" + fmt(total) + "</strong> (₦" + fmt(ngn) + ") now on Paystack, and every store moves to the new price. Continue?";
                }
                var m = document.getElementById('confirmModal');
                if (m) { m.hidden = false; }
            };
            window.closeConfirm = function () {
                var m = document.getElementById('confirmModal');
                if (m) { m.hidden = true; }
            };
            window.proceedPay = function () {
                var f = document.getElementById('subscribeForm');
                if (f) { f.submit(); }
            };
        })();
    </script>
}
