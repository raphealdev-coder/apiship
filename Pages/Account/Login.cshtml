@page
@model apiship.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<section class="onboard-hero">
    <div class="container text-center">
        <span class="badge-pill">Welcome back</span>
        <h1>Sign in</h1>
        <p>Access your dashboard, deployments and downloads.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="success-card mx-auto" style="max-width:440px;">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            <form method="post" class="onboard-form" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3 text-start">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="jane@company.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="mb-3 text-start">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-brand btn-lg w-100">Sign in</button>
            </form>
            <p class="text-muted mt-3 mb-0">No account yet? <a asp-page="/Account/Register">Create one</a></p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
