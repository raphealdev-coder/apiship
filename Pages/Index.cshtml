@page
@model IndexModel
@{
    ViewData["Title"] = "APIs made simple";
}

<!-- Hero -->
<section class="hero">
    <div class="container text-center">
        <span class="badge-pill">API as a Service</span>
        <h1 class="hero-title">Ship powerful APIs<br />without the heavy lifting</h1>
        <p class="hero-sub">ApiShip gives developers fast, secure and scalable API infrastructure so you can
            build, connect and deliver in minutes instead of months.</p>
        <div class="hero-actions">
            <a asp-page="/GetStarted" class="btn btn-brand btn-lg">Start free trial</a>
            <a href="/#features" class="btn btn-outline-light btn-lg">Explore features</a>
        </div>
        <div class="hero-stats">
            <div><strong>99.99%</strong><span>Uptime SLA</span></div>
            <div><strong>40ms</strong><span>Avg. latency</span></div>
            <div><strong>12k+</strong><span>Developers</span></div>
        </div>
        <div class="terminal-card">
            <div class="terminal-bar">
                <span class="tdot tred"></span><span class="tdot tyellow"></span><span class="tdot tgreen"></span>
                <span class="terminal-title">bash — apiship</span>
            </div>
            <div class="terminal-body">
                <div class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">curl https://api.apiship.app/v1/data \</span></div>
                <div class="t-line">     <span class="t-cmd">-H "Authorization: Bearer sk_live_••••••••"</span></div>
                <div class="t-line t-gap"> </div>
                <div class="t-line"><span class="t-out">{</span></div>
                <div class="t-line"><span class="t-out">  "status": <span class="t-ok">"ok"</span>,</span></div>
                <div class="t-line"><span class="t-out">  "latency_ms": <span class="t-num">38</span>,</span></div>
                <div class="t-line"><span class="t-out">  "records": <span class="t-num">1240</span></span></div>
                <div class="t-line"><span class="t-out">}</span><span class="t-caret"></span></div>
            </div>
        </div>
    </div>
</section>

<!-- API Introduction -->
<section id="intro" class="section section-dark">
    <div class="container">
        <div class="section-head text-center">
            <span class="badge-pill"><span class="brand-dot"></span> API Introduction</span>
            <h2 class="text-white intro-title">Start Building with Powerful,<br />Reliable API Infrastructure</h2>
            <p class="text-light-muted">Learn the basics of our API platform—authentication, endpoints, and
                best practices to build fast, secure, and scalable applications from day one.</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="intro-card h-100">
                    <div class="intro-icon">🛡️</div>
                    <div>
                        <h3>What is Our API?</h3>
                        <p>Our API allows you to integrate core functionalities into your app, including data
                            retrieval, user management, and real-time interactions.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="intro-card h-100">
                    <div class="intro-icon">👥</div>
                    <div>
                        <h3>Who It's For</h3>
                        <p>Built for developers, startups and enterprises that need reliable infrastructure
                            without managing servers, scaling or security themselves.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="intro-card h-100">
                    <div class="intro-icon">⚙️</div>
                    <div>
                        <h3>How It Works</h3>
                        <p>Authenticate with an API key, call clean REST endpoints, and get fast JSON responses
                            served from our global edge network.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="intro-card h-100">
                    <div class="intro-icon">🚀</div>
                    <div>
                        <h3>Getting Started Quickly</h3>
                        <p>Sign up, grab your keys and make your first request in minutes with our SDKs,
                            guides and ready-to-copy code samples.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section id="features" class="section">
    <div class="container">
        <div class="section-head text-center">
            <span class="eyebrow">Features</span>
            <h2>Everything you need to run APIs at scale</h2>
            <p>A complete toolkit to design, secure and monitor every endpoint.</p>
        </div>
        <div class="row g-4">
            @foreach (var f in Model.Features)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card h-100">
                        <div class="feature-icon">@f.Icon</div>
                        <h3>@f.Title</h3>
                        <p>@f.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- API product types -->
<section id="apis" class="section section-alt">
    <div class="container">
        <div class="section-head text-center">
            <span class="eyebrow">API types</span>
            <h2>Connect any part of your store</h2>
            <p>Pick the APIs you need — mix and match across all your stores.</p>
        </div>
        <div class="row g-4">
            @foreach (var api in apiship.Data.ApiProductCatalog.Products)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="api-type-card h-100">
                        <div class="api-type-icon">@api.Icon</div>
                        <h3>@api.Name</h3>
                        <p>@api.Summary</p>
                        <a asp-page="/GetStarted" class="api-type-link">Start with this API →</a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Analytics -->
<section id="analytics" class="section section-dark">
    <div class="container">
        <div class="section-head text-center">
            <span class="eyebrow eyebrow-light">Analytics</span>
            <h2 class="text-white">Real-time insight into every request</h2>
            <p class="text-light-muted">Track traffic, latency and errors from one live dashboard.</p>
        </div>
        <div class="dashboard-card">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="chart-head">
                        <div>
                            <span class="chart-title">API requests</span>
                            <span class="chart-value">4.82M<small>this month</small></span>
                        </div>
                        <span class="chart-trend">▲ 18.4%</span>
                    </div>
                    <canvas id="requestsChart" height="150"></canvas>
                </div>
                <div class="col-lg-4">
                    <span class="chart-title">Traffic by endpoint</span>
                    <canvas id="endpointChart" height="180"></canvas>
                    <div class="mini-stats">
                        <div><span class="dot dot-1"></span>/v1/data <strong>46%</strong></div>
                        <div><span class="dot dot-2"></span>/v1/auth <strong>29%</strong></div>
                        <div><span class="dot dot-3"></span>/v1/files <strong>15%</strong></div>
                        <div><span class="dot dot-4"></span>other <strong>10%</strong></div>
                    </div>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-6 col-md-3"><div class="kpi"><span>Avg latency</span><strong>38ms</strong></div></div>
                <div class="col-6 col-md-3"><div class="kpi"><span>Success rate</span><strong>99.98%</strong></div></div>
                <div class="col-6 col-md-3"><div class="kpi"><span>Error rate</span><strong>0.02%</strong></div></div>
                <div class="col-6 col-md-3"><div class="kpi"><span>Active keys</span><strong>1,204</strong></div></div>
            </div>
        </div>
    </div>
</section>

<!-- How it works -->
<section id="how" class="section">
    <div class="container">
        <div class="section-head text-center">
            <span class="eyebrow">How it works</span>
            <h2>Go live in three simple steps</h2>
            <p>From sign-up to production in minutes.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-card h-100">
                    <span class="step-num">01</span>
                    <h3>Create your account</h3>
                    <p>Pick a plan and get instant access to your API keys and dashboard.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card h-100">
                    <span class="step-num">02</span>
                    <h3>Connect your app</h3>
                    <p>Drop in our SDK or call the REST endpoints directly — just a few lines of code.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card h-100">
                    <span class="step-num">03</span>
                    <h3>Scale with confidence</h3>
                    <p>Monitor usage in real time while we handle scaling, security and uptime.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Trusted partners -->
<section id="partners" class="section section-alt partners-section">
    <div class="container">
        <div class="section-head text-center">
            <span class="eyebrow">Trusted partners</span>
            <h2>Powering teams at fast-growing companies</h2>
            <p>Thousands of developers and businesses build on ApiShip.</p>
        </div>
    </div>
    <div class="marquee">
        <div class="marquee-track">
            @foreach (var p in Model.Partners.Concat(Model.Partners))
            {
                <div class="logo-chip"><img src="@p.Logo" alt="@p.Name logo" class="logo-mark" /> @p.Name</div>
            }
        </div>
    </div>
    <div class="marquee">
        <div class="marquee-track marquee-reverse">
            @foreach (var p in Model.Partners.AsEnumerable().Reverse().Concat(Model.Partners.AsEnumerable().Reverse()))
            {
                <div class="logo-chip"><img src="@p.Logo" alt="@p.Name logo" class="logo-mark" /> @p.Name</div>
            }
        </div>
    </div>
</section>

<!-- Reviews -->
<section id="reviews" class="section section-alt">
    <div class="container">
        <div class="section-head text-center">
            <span class="eyebrow">Customer reviews</span>
            <h2>Loved by developer teams</h2>
            <p>See what our customers say about building with ApiShip.</p>
        </div>
        <div class="row g-4">
            @foreach (var r in Model.Reviews)
            {
                <div class="col-md-4">
                    <div class="review-card h-100">
                        <div class="stars">★★★★★</div>
                        <p class="review-text">“@r.Quote”</p>
                        <div class="review-author">
                            <span class="avatar">@r.Initials</span>
                            <div>
                                <strong>@r.Name</strong>
                                <small>@r.Role</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Pricing -->
<section id="pricing" class="section">
    <div class="container">
        <div class="section-head text-center">
            <span class="eyebrow">Pricing</span>
            <h2>Simple plans that scale with you</h2>
            <p>Start at $50/month. No hidden fees, cancel anytime.</p>
        </div>
        <div class="row g-4 justify-content-center">
            @foreach (var p in Model.Plans)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="pricing-card h-100 @(p.Featured ? "featured" : "")">
                        @if (p.Featured)
                        {
                            <span class="popular">Most popular</span>
                        }
                        <h3>@p.Name</h3>
                        <div class="price"><span class="amount">$@p.Price</span><span class="period">/mo</span></div>
                        <p class="plan-desc">@p.Description</p>
                        <ul class="plan-features">
                            @foreach (var item in p.Features)
                            {
                                <li>@item</li>
                            }
                        </ul>
                        <a asp-page="/GetStarted" asp-route-plan="@p.Name" class="btn @(p.Featured ? "btn-brand" : "btn-outline-brand") w-100">Choose @p.Name</a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta">
    <div class="container text-center">
        <h2>Ready to ship your first API?</h2>
        <p>Join thousands of developers building faster with ApiShip.</p>
        <a asp-page="/GetStarted" asp-route-plan="Starter" class="btn btn-brand btn-lg">Get started for $50/mo</a>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var brand = '#6c5ce7', brand2 = '#00d2ff';
            var reqEl = document.getElementById('requestsChart');
            if (reqEl && window.Chart) {
                var ctx = reqEl.getContext('2d');
                var grad = ctx.createLinearGradient(0, 0, 0, 220);
                grad.addColorStop(0, 'rgba(108,92,231,0.35)');
                grad.addColorStop(1, 'rgba(108,92,231,0)');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                        datasets: [{
                            label: 'Requests',
                            data: [520000, 610000, 580000, 720000, 690000, 840000, 760000],
                            borderColor: brand,
                            backgroundColor: grad,
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4,
                            pointRadius: 3,
                            pointBackgroundColor: brand2
                        }]
                    },
                    options: {
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { grid: { color: 'rgba(255,255,255,0.06)' }, ticks: { color: '#9aa0b2' } },
                            y: { grid: { color: 'rgba(255,255,255,0.06)' }, ticks: { color: '#9aa0b2' } }
                        }
                    }
                });
            }
            var epEl = document.getElementById('endpointChart');
            if (epEl && window.Chart) {
                new Chart(epEl, {
                    type: 'doughnut',
                    data: {
                        labels: ['/v1/data', '/v1/auth', '/v1/files', 'other'],
                        datasets: [{
                            data: [46, 29, 15, 10],
                            backgroundColor: [brand, brand2, '#22c55e', '#3b4258'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        cutout: '68%',
                        plugins: { legend: { display: false } }
                    }
                });
            }
        })();
    </script>
}
