@page
@model apiship.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "Settings";
    ViewData["ActiveNav"] = "settings";
}

<section class="admin-topbar">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <span class="admin-logo-dot"></span>
            <div>
                <span class="admin-eyebrow">ApiShip · Admin</span>
                <h1 class="admin-title">Settings</h1>
            </div>
        </div>
        <form method="post" asp-page-handler="Logout">
            <button type="submit" class="btn admin-btn-ghost">Log out</button>
        </form>
    </div>
</section>

<partial name="_AdminNav" />

<section class="admin-body">
    <div class="container">
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="admin-flash">@Model.StatusMessage</div>
        }

        <div class="admin-panel admin-detail mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h2 class="admin-detail-heading mb-0" style="border:0;">Payment settings</h2>
                <span class="@(Model.HasPaystackKey ? "settings-ok" : "settings-warn")">
                    @(Model.HasPaystackKey ? "Paystack key set" : "No Paystack key")
                </span>
            </div>
            <hr class="settings-rule" />

            <form method="post" asp-page-handler="Payment" class="onboard-form">
                <div class="mb-3">
                    <label class="admin-field-label">Developer Paystack secret key</label>
                    <input asp-for="Payment.PaystackSecretKey" class="form-control"
                           placeholder="•••••••••  (leave blank to keep)" autocomplete="off" />
                    <small class="text-muted">The Paystack account that receives subscription payments. Use a <strong>test</strong> key first to try the flow.</small>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="admin-field-label">Price / store / month ($)</label>
                        <input asp-for="Payment.PriceMonthlyUsd" type="number" min="0" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="admin-field-label">Price / store / year ($)</label>
                        <input asp-for="Payment.PriceYearlyUsd" type="number" min="0" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="admin-field-label">USD → NGN rate</label>
                        <input asp-for="Payment.UsdToNgnRate" type="number" step="0.01" min="0" class="form-control"
                               placeholder="live (@apiship.Data.AppSetting.FallbackRate)" />
                    </div>
                </div>
                <small class="text-muted d-block mt-2">
                    Prices are in USD. Cards are charged in Naira — leave the rate blank to use the fallback rate
                    (currently ₦@apiship.Data.AppSetting.FallbackRate/$), or pin your own.
                </small>
                <button type="submit" class="btn admin-btn-primary mt-3">Save payment settings</button>
            </form>
        </div>

        <div class="admin-panel admin-detail">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h2 class="admin-detail-heading mb-0" style="border:0;">Customer account reminder banner</h2>
                <span class="text-muted small">Shows to customers · edited here only</span>
            </div>
            <hr class="settings-rule" />

            <form method="post" asp-page-handler="Reminder" class="onboard-form">
                <label class="admin-check mb-3">
                    <input asp-for="Reminder.Enabled" type="checkbox" />
                    <span>Show the amber “trial connector expiring” reminder across the customer account</span>
                </label>
                <div class="mb-3">
                    <label class="admin-field-label">Expiry date</label>
                    <input asp-for="Reminder.ExpiryUtc" type="date" class="form-control" style="max-width:320px;" />
                </div>
                <div class="mb-3">
                    <label class="admin-field-label">Custom message (optional)</label>
                    <textarea asp-for="Reminder.Message" class="form-control" rows="3"
                              placeholder="Leave blank to use the default wording about avoiding synchronisation errors between stores."></textarea>
                </div>
                <button type="submit" class="btn admin-btn-primary">Save notice</button>
            </form>
        </div>
    </div>
</section>
