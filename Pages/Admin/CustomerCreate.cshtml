@page
@model apiship.Pages.Admin.CustomerCreateModel
@{
    ViewData["Title"] = "New customer";
    ViewData["ActiveNav"] = "customers";
}

<section class="admin-topbar">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <a asp-page="/Admin/Customers" class="admin-back">←</a>
            <div>
                <span class="admin-eyebrow">Customers</span>
                <h1 class="admin-title">New customer</h1>
            </div>
        </div>
        <form method="post" asp-page-handler="Logout">
            <button type="submit" class="btn admin-btn-ghost">Log out</button>
        </form>
    </div>
</section>

<partial name="_AdminNav" />

<section class="admin-body">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="admin-panel admin-detail">
                    <form method="post" class="onboard-form" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Input.FullName" class="form-label"></label>
                                <input asp-for="Input.FullName" class="form-control" autocomplete="off" />
                                <span asp-validation-for="Input.FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Email" class="form-label"></label>
                                <input asp-for="Input.Email" class="form-control" autocomplete="off" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Company" class="form-label"></label>
                                <input asp-for="Input.Company" class="form-control" autocomplete="off" />
                                <span asp-validation-for="Input.Company" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Password" class="form-label"></label>
                                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                                <small class="text-muted">Leave blank to let the customer set it via self sign-up.</small>
                            </div>
                            <div class="col-12">
                                <label class="admin-check">
                                    <input asp-for="Input.Suspended" type="checkbox" />
                                    <span>Create as suspended (blocks sign-in)</span>
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn admin-btn-primary">Create customer</button>
                            <a asp-page="/Admin/Customers" class="btn admin-btn-ghost">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
